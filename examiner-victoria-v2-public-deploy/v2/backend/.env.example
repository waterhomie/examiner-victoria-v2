# Examiner Victoria V2 backend environment example
#
# Copy these values into your backend hosting provider's environment-variable
# settings. Do not commit a real .env file with private API keys.

API_KEY=sk-your-provider-key
BASE_URL=https://api.gptsapi.net/v1
MODEL=gpt-5.4-mini
TRANSCRIPTION_MODEL=whisper-1

# For the first one-service public test, "*" is acceptable. Before wider public
# sharing, replace it with the real deployed domain.
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Safety limits for public testing.
MAX_AUDIO_UPLOAD_MB=12
RATE_LIMIT_PER_MINUTE=120
MAX_ANSWER_CHARS=4000
MAX_SESSION_MESSAGES=120
MAX_TTS_CHARS=1200
TTS_CACHE_MAX_ITEMS=64
