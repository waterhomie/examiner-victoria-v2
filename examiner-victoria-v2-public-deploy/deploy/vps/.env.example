# Copy this file to deploy/vps/.env on the VPS.
# Do not commit the real .env file.

DOMAIN=example.com
ACME_EMAIL=you@example.com

API_KEY=sk-your-real-provider-key
BASE_URL=https://api.gptsapi.net/v1
MODEL=gpt-5.4-mini
TRANSCRIPTION_MODEL=whisper-1

# For one-domain VPS deployment, use the same HTTPS domain that Caddy serves.
CORS_ORIGINS=https://example.com

MAX_AUDIO_UPLOAD_MB=12
RATE_LIMIT_PER_MINUTE=120
MAX_ANSWER_CHARS=4000
MAX_SESSION_MESSAGES=120
MAX_TTS_CHARS=1200
TTS_CACHE_MAX_ITEMS=64
